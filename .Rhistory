library(ggraph)
data_sim <- simulate_bell(
W = W,
n_months  = n_months,
n_years   = n_years,
beta      = beta,
sd_month  = sd_month,
n_sim = 1
)
g <- graph_from_adjacency_matrix(W, mode = "undirected")
map_df <- data_sim %>%
filter(year == 1, month == 10) %>%
arrange(region)   # importante: para alinear con W
g <- set_vertex_attr(g, "mu", value = exp(map_df$eta))
ggraph(g, layout = "fr") +
geom_edge_link(alpha = 0.3) +
geom_node_point(aes(color = mu), size = 5) +
scale_color_viridis_c() +
theme_void()
simulate_RW1(n_months, sd_esp = sd_month)
simulate_RW1(n_months, sd_esp = sd_month)
# Función para simular BYM2 escalado
simulate_bym2 <- function(W, sigma = 5, rho = 0.9, eps = 1e-6) {
n <- nrow(W)
D <- diag(rowSums(W))
Q <- D - W    # ICAR puro
# Regularización mínima solo para cálculo numérico
Q_reg <- Q + eps * diag(n)
# Pseudoinversa (ICAR no es invertible)
Q_inv <- MASS::ginv(Q)
# Escala BYM2 basada en GM diagonal de pseudoinversa
c <- exp(mean(log(diag(Q_inv))))
# Simular componente estructurado ICAR
phi_raw <- as.numeric(MASS::mvrnorm(1, rep(0,n), Sigma = Q_inv))
phi_star <- phi_raw / sqrt(c)
# Componente no estructurado
theta <- rnorm(n)
# Efecto BYM2
S <- sigma * ( sqrt(rho) * phi_star + sqrt(1 - rho) * theta )
list(
S = S,
phi_star = phi_star,
theta = theta,
Q = Q,
c = c
)
}
simulate_RW1(n_months, sd_esp = sd_month)
simulate_RW1(n_months, sd_esp = sd_month)
simulate_RW1(n_months, sd_esp = sd_month)
n_months
simulate_bym2(W = W)$S
simulate_bym2(W = W)$S
simulate_bym2(W = W)$S
simulate_bym2
